# Configuración de Base de Datos
DATABASE_URL=postgresql://clv_user:clv_password@localhost:5432/clv_database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=clv_database
DB_USER=clv_user
DB_PASSWORD=clv_password

# MLflow Configuration
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=CLV_Forecasting
MLFLOW_ARTIFACT_LOCATION=./mlartifacts

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=true

# Configuración de Seguridad
SECRET_KEY=your-secret-key-here-change-in-production
API_KEY=your-api-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AWS Configuration (si se usa S3 para DVC)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET_NAME=clv-forecasting-data

# Configuración de Logging
LOG_LEVEL=INFO
LOG_FILE=logs/clv_forecasting.log

# Configuración de Monitoreo
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Configuración de Alertas
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
EMAIL_ALERTS_ENABLED=false
ALERT_EMAIL=alerts@example.com

# Configuración del Modelo
MODEL_PATH=models/
MODEL_VERSION=latest
PREDICTION_THRESHOLD=0.5

# Feature Store (opcional)
FEATURE_STORE_ENABLED=false
FEATURE_STORE_URL=http://localhost:8001

# Configuración de Cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
CACHE_TTL=3600

# Configuración de Desarrollo
DEBUG=false
TESTING=false
ENVIRONMENT=development
